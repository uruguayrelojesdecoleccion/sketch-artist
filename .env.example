# OpenAI API Configuration
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Firecrawl API Configuration (opcional)
# Obtén tu API key en: https://firecrawl.dev/
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Supabase Configuration (ya configurado automáticamente)
# Estas variables se configuran automáticamente en Supabase Dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Variables de entorno para desarrollo local
# Copia este archivo a .env.local y configura tus valores 